# PostgreSQL (local docker db only)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lexflowdb

# App DB connection (single source of truth)
# Local docker:
# DATABASE_URL=postgresql+asyncpg://admin:change-me@db:5432/lexflowdb
# Render:
# DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>/<db>
DATABASE_URL=postgresql+asyncpg://admin:change-me@db:5432/lexflowdb

# Security
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Configuration
AI_PROVIDER=cohere
COHERE_API_KEY=your_cohere_api_key_here
COHERE_BASE_URL=https://api.cohere.com
COHERE_COMPAT_BASE_URL=https://api.cohere.ai/compatibility/v1
COHERE_MODEL=command-r-03-2025
COHERE_EMBEDDING_MODEL=embed-english-v3.0
COHERE_EMBEDDING_DIM=768
COHERE_TIMEOUT_SECONDS=120

# Processing Mode
DOCUMENT_PROCESSING_MODE=background
AI_TAG_MIN_CONFIDENCE=0.55
AI_TAG_MAX_PER_DOCUMENT=8

# Reaper Configuration
DOCUMENT_STUCK_MINUTES=30

# Storage Backend: "b2" | "r2" | "s3" | "local"
# Current (MVP): b2
# AWS migration: change to s3 and fill S3_* vars
STORAGE_BACKEND=b2

# AWS S3 (fill when migrating to AWS)
# STORAGE_BACKEND=s3
# S3_BUCKET_NAME=lexflow-files
# S3_REGION=eu-central-1
# S3_ACCESS_KEY_ID=<aws-access-key>
# S3_SECRET_ACCESS_KEY=<aws-secret-key>

# Seed Data (auto-seeded on first deploy)
SEED_ORG_NAME=LexFlow
SEED_ORG_SLUG=lexflow
SEED_ADMIN_EMAIL=admin@lexflow.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ORG_ADMIN_EMAIL=orgadmin@lexflow.com
SEED_ORG_ADMIN_PASSWORD=change-me-strong-password

# Environment
APP_ENV=development
