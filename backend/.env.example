# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://admin:change-me@localhost:5432/lexflow_db
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=change-me
DB_NAME=lexflow_db

# Security
SECRET_KEY=generate_a_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend AI
GEMINI_API_KEY=your_gemini_api_key_here

# AI Provider selection: gemini | ollama | openrouter | cohere
AI_PROVIDER=gemini

# Ollama (local) settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Must match pgvector column dimension (default 768)
OLLAMA_EMBEDDING_DIM=768
OLLAMA_TIMEOUT_SECONDS=120

# Cohere settings
COHERE_API_KEY=your_cohere_api_key_here
COHERE_BASE_URL=https://api.cohere.ai
COHERE_MODEL=command-r
COHERE_EMBEDDING_MODEL=embed-english-v3.0
COHERE_EMBEDDING_DIM=768
COHERE_TIMEOUT_SECONDS=120

# Document Processing Flow
# DOCUMENT_PROCESSING_MODE: auto | celery | background
DOCUMENT_PROCESSING_MODE=auto
# If mode=auto, files >= this size (MB) go to Celery
DOCUMENT_PROCESSING_CELERY_MIN_MB=10
# Hard cutoff for total processing time (seconds). When exceeded, finish without AI.
DOCUMENT_MAX_PROCESSING_SECONDS=3600

# AI tag filtering
AI_TAG_MIN_CONFIDENCE=0.55
AI_TAG_MAX_PER_DOCUMENT=8

# Embedding fan-out (Celery only)
DOCUMENT_EMBEDDING_FANOUT=true

# AI analysis timeout (seconds)
AI_ANALYSIS_TIMEOUT_SECONDS=120

# Reaper: mark stuck docs as completed_without_ai after this many minutes
DOCUMENT_STUCK_MINUTES=30
